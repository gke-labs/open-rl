flowchart TD
    %% Define Styles
    classDef k8s fill:#326ce5,stroke:#fff,stroke-width:2px,color:#fff;
    classDef storage fill:#19a45b,stroke:#fff,stroke-width:2px,color:#fff;
    classDef ext fill:#888,stroke:#fff,stroke-width:2px,color:#fff;
    classDef broker fill:#d82c20,stroke:#fff,stroke-width:2px,color:#fff;

    %% External Clients
    Client["Client (Trainer Loop)"]:::ext
    
    subgraph "Google Kubernetes Engine (GKE)"
        %% API Gateway Layer
        Gateway["open-rl-gateway<br/>(PyTorch / HTTP API)"]:::k8s
        
        %% State Broker
        Redis["redis-broker<br/>(Async State / Pub-Sub)"]:::broker
        
        %% Worker Layer
        subgraph "vLLM Inference Subsystem"
            Worker1["vllm-worker (L4 GPU)"]:::k8s
            Worker2["vllm-worker (L4 GPU)"]:::k8s
            Worker3["vllm-worker (Auto-scaled)"]:::k8s
        end
        
        %% Distributed Storage
        Lustre[("open-rl-lustre-pvc<br/>(Google Managed Lustre 1000MB/s)")]:::storage
        
    end

    %% Communication Flows
    Client -- "1. Send Chat Request / Save LoRA Weights" --> Gateway
    Gateway -- "2. Write Safetensors" --> Lustre
    Gateway -- "3. Enqueue Sampling Task" --> Redis
    
    Redis -. "4. Poll / Stream State" .-> Worker1
    Redis -. "4. Poll / Stream State" .-> Worker2
    Redis -. "4. Poll / Stream State" .-> Worker3
    
    Worker1 -- "5. Hot-swap specific vLLM adapter via Mount" --> Lustre
    Worker2 -- "5. Hot-swap specific vLLM adapter via Mount" --> Lustre
    
    Worker1 -- "6. Return Inference Generation" --> Redis
    Redis -- "7. Return Result" --> Gateway
    
    Gateway -- "8. HTTP Response" --> Client
